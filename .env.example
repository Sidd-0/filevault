# Backend Environment Variables
# Copy this file to .env and update with your values

# Database Configuration
DATABASE_URL=postgres://admin:password123@localhost:5432/filevault?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password123
DB_NAME=filevault

# Server Configuration
PORT=8080
HOST=0.0.0.0

# File Upload Settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600  # 100MB in bytes
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,text/plain

# Rate Limiting
RATE_LIMIT_REQUESTS=2  # Requests per second
RATE_LIMIT_BURST=5     # Burst capacity

# Storage Quotas
DEFAULT_USER_QUOTA=10485760  # 10MB in bytes
ADMIN_QUOTA=104857600        # 100MB in bytes

# Security
JWT_SECRET=your-secret-key-change-this-in-production
SESSION_SECRET=another-secret-key-change-this-too
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8080/api

# Environment
ENVIRONMENT=development  # development, staging, production

# Logging
LOG_LEVEL=info  # debug, info, warn, error
LOG_FORMAT=json # json, text

# Optional: External Services
# S3_BUCKET=filevault-storage
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Redis (for caching - optional)
# REDIS_URL=redis://localhost:6379

# Monitoring (optional)
# SENTRY_DSN=
# PROMETHEUS_PORT=9090
