{
  "name": "filevault-frontend",
  "version": "1.0.0",
  "description": "File Vault Frontend - Secure file storage UI",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "react-dropzone": "^14.2.3",
    "react-modal": "^3.16.1",
    "axios": "^1.6.2",
    "date-fns": "^3.0.6",
    "web-vitals": "^3.5.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint src/**/*.{js,jsx}",
    "format": "prettier --write src/**/*.{js,jsx,json,css}"
  },
  "eslintConfig": {
    "extends": [
